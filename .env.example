# LineDecor - Variáveis de Ambiente
# Copie para .env e preencha com seus dados

# === SERVIDOR ===
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# === BANCO DE DADOS ===
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=linedecor

# === AUTENTICAÇÃO ===
JWT_SECRET=linedecor-secret-key-change-in-prod-2024

# === EMAIL (SMTP) ===
# Gmail: use App Password (conta.google.com > Segurança > Senhas de app)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha_de_app_16_caracteres
SMTP_FROM="LineDecor <seu_email@gmail.com>"
EMAIL_EMPRESA=contato@suaempresa.com.br
TELEFONE_EMPRESA=(11) 97108-0410

# === PAGAMENTO (STRIPE) ===
STRIPE_SECRET_KEY=sk_test_seu_stripe_secret_key_aqui
STRIPE_PUBLIC_KEY=pk_test_seu_stripe_public_key_aqui
STRIPE_WEBHOOK_SECRET=whsec_seu_webhook_secret_aqui

# === COMUNICAÇÃO ===
# Twilio WhatsApp (opcional)
TWILIO_SID=seu_twilio_sid
TWILIO_TOKEN=seu_twilio_token
TWILIO_PHONE=+5511999999999

# === AUTOMAÇÕES ===
# Google Sheets - ID da planilha
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_CREDENTIALS=

# === CONFIGURAÇÕES ===
FRETE_GRATIS_MINIMO=299
