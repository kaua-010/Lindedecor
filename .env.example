# LineDecor - Variáveis de Ambiente
# Copie para .env e preencha com seus dados

PORT=3000

# Email da empresa (recebe notificações)
EMAIL_EMPRESA=contato@suaempresa.com.br
TELEFONE_EMPRESA=(11) 99999-9999

# SMTP - Gmail: use App Password (conta.google.com > Segurança > Senhas de app)
# Outlook: smtp.office365.com, porta 587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha_de_app_16_caracteres
SMTP_FROM="LineDecor <seu_email@gmail.com>"

# SMS via Twilio (opcional - deixe vazio se não usar)
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_PHONE=+5511999999999

# Google Sheets - ID da planilha (ex: https://docs.google.com/spreadsheets/d/ESTE_ID_AQUI/edit)
GOOGLE_SHEETS_ID=
# Credenciais JSON (conta de serviço) - colar como string escapada

# Frete grátis acima de (R$)
FRETE_GRATIS_MINIMO=299
